generator client {
  provider = "prisma-client-js"
  // Repo-root folder (not under src/) so IDEs are less likely to lock query_engine-windows.dll.node on Windows.
  output   = "../.prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// One row per calendar day (operational departure in local sense) + flight + route leg.
model DailyCompare {
  id                     String   @id @default(cuid())
  compareDate            DateTime @db.Date
  flight                 String
  routeKey               String
  plannedEquipment       String?
  plannedQsuiteApi       Boolean?
  plannedQueryDate       String?
  plannedDepartureLocal  String?
  actualRegistration     String?
  actualAircraftCell     String?
  actualEquipment        String?
  actualQsuiteFromTail   Boolean?
  matchQsuite            Boolean?
  matchEquipment         Boolean?
  fr24Error              String?
  /// Parsed Airfleets.net aircraft page (cron); shown on registration hover.
  airfleetsPayload       Json?
  source                 String   @default("fr24")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([compareDate, flight, routeKey])
  @@index([compareDate])
}

/// Qatar segments export (one row per `flight_id` from Python BFF exporter).
model PlannedSegment {
  id                String   @id @default(cuid())
  flightId          String   @unique
  queryDate         String
  flightNumber      String
  origin            String
  destination       String
  departureLocal    String
  arrivalLocal      String
  vehicleCode       String
  vehicleName       String
  vehicleShort      String
  durationSec       Int?
  qsuiteEquipped    Boolean?
  starlink          Boolean?
  operatingAirline  String?
  offerOrigin       String?
  offerDestination  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([flightNumber, origin, destination])
  @@index([queryDate])
}

/// Daily SerpAPI Google Flights snapshot for a fixed AMS→DOH→MNL Qatar bundle (cron).
model TrackedBundlePriceSnapshot {
  id                      String   @id @default(cuid())
  observedAt              DateTime @default(now())
  /// Outbound AMS departure date of the shopped itinerary (first multi-city leg).
  bundleFirstLegDate      DateTime @db.Date
  cabin                   String
  priceTotal              Int?
  currency                String   @default("EUR")
  matchedBundle           Boolean  @default(false)
  /// Set for BUSINESS only: true when suite markers appear in the matched itinerary payload.
  qsuiteIndicatorsPresent Boolean?
  flightNumbersSummary    String?
  error                   String?
  serpSearchId            String?

  @@index([bundleFirstLegDate, cabin, observedAt])
}
