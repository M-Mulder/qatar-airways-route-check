# Copy to .env then .env.local and replace placeholders (never commit real secrets).
# Next.js loads .env then .env.local in development.

# Postgres (Vercel Postgres, Neon, or any provider — use a dedicated DB for this app)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Secret for Vercel Cron -> GET /api/cron/compare (Authorization: Bearer <value>)
CRON_SECRET="use-a-long-random-string"

# SerpAPI (Google Flights) — daily bundle price + Qsuite amenity check (see /pricing). Set in Vercel as SERPAPI_KEY.
# SERPAPI_KEY=""
#
# Optional overrides for the tracked AMS→DOH→MNL itinerary (defaults: 2026-10-11 / 2026-10-12, QR274 + QR934).
# TRACKED_BUNDLE_FIRST_LEG_DATE="2026-10-11"
# TRACKED_BUNDLE_SECOND_LEG_DATE="2026-10-12"
# TRACKED_BUNDLE_FLIGHT_NUMBERS="274,934"
# When exact flight numbers are not in SerpAPI results, match by airport chain (codeshare-friendly). Set to 1 to disable.
# TRACKED_BUNDLE_SKIP_ROUTE_FALLBACK="1"
# TRACKED_BUNDLE_ORIGIN="AMS"
# TRACKED_BUNDLE_HUB="DOH"
# TRACKED_BUNDLE_DEST="MNL"
# TRACKED_BUNDLE_HL="nl"
# TRACKED_BUNDLE_GL="nl"
# TRACKED_BUNDLE_CURRENCY="EUR"
# Adults (total fare is for all adults). Default 2.
# TRACKED_BUNDLE_ADULTS="2"
# Official seller in Google Flights booking options (`booking_options[].together.book_with` when `airline: true`). Not OTAs.
# TRACKED_OFFICIAL_BOOK_WITH="Qatar Airways"
#
# Verbose `[pricing:serp]` logs (request/response summaries). Set to 0 to reduce noise.
# PRICING_VERBOSE="0"
#
# Include “View more flights” style results (long Doha connections, QR274+QR934). Set to 0 to disable (faster, fewer rows).
# TRACKED_BUNDLE_SHOW_HIDDEN="0"
#
# If multi-city SerpAPI search does not return a QR274+934 bundle, try one-way AMS→MNL (default). Set to 1 to disable.
# TRACKED_BUNDLE_SKIP_ONE_WAY_FALLBACK="1"

# Optional: comma-separated flight numbers to check (defaults in code: QR274,QR284,QR934)
COMPARE_FLIGHTS="QR274,QR284,QR934"

# Airfleets.net + Flightradar24 history: with SERPER_API_KEY, cron uses Serper scrape (no Playwright). Else FR24 is a
# direct HTTP GET (often HTTP 403); Airfleets falls back to playwright-core on Vercel (@sparticuz/chromium) or Chrome
# locally. Plain HTTP hits captcha/Cloudflare.
#
# FR24: tries direct GET first, then Serper scrape, then headless Chrome when still no parsable `#tbl-datatable`.
# The FR24 browser is closed before Airfleets Playwright runs (avoids stacking two Chromium instances).
# FR24_PLAYWRIGHT=0  # set to skip FR24 Chromium (error stubs if Serper/direct cannot parse rows)
# SERPER_API_KEY=""
# AIRFLEETS_BROWSER=0
#
# Extra `[Airfleets]` JSON lines in server logs (snapshots every ~20s while waiting, goto steps, retries).
# On Vercel this defaults ON; set to 0 to reduce noise. Locally defaults OFF unless set to 1.
# AIRFLEETS_VERBOSE_LOG=1
# AIRFLEETS_VERBOSE_LOG=0
#
# Optional: Google Programmable Search — Airfleets cron tries indexed ficheapp snippets first (no Playwright).
# Create a search engine + API key: https://developers.google.com/custom-search/v1/overview
# GOOGLE_CSE_API_KEY=""
# GOOGLE_CSE_ID=""
#
# Optional: Playwright opens Google for "{reg} Airfleets" and clicks first airfleets.net result (often the plane page).
# Default off — Google frequently challenges datacenter IPs; respect https://policies.google.com/terms
# AIRFLEETS_PLAYWRIGHT_GOOGLE_ENTRY=1
#
# Optional local overrides (see README):
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH="C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"
# PLAYWRIGHT_AIRFLEETS_CHANNEL=chrome
# PLAYWRIGHT_AIRFLEETS_HEADED=1
