# Postgres (Vercel Postgres / Neon / local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Secret for Vercel Cron -> /api/cron/compare (Authorization: Bearer <value>)
CRON_SECRET="generate-a-long-random-string"

# Public URL of your Qatar segments CSV (raw GitHub, Blob, etc.)
PLANNED_DATA_URL="https://raw.githubusercontent.com/.../qatar_segments_export.csv"

# Comma-separated IATA flight numbers to compare (default in code: QR274,QR284,QR934)
COMPARE_FLIGHTS="QR274,QR284,QR934"
