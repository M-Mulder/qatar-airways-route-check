# Copy to .env then .env.local and replace placeholders (never commit real secrets).
# Next.js loads .env then .env.local in development.

# Postgres (Vercel Postgres, Neon, or any provider — use a dedicated DB for this app)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Secret for Vercel Cron -> GET /api/cron/compare (Authorization: Bearer <value>)
CRON_SECRET="use-a-long-random-string"

# Optional: comma-separated flight numbers to check (defaults in code: QR274,QR284,QR934)
COMPARE_FLIGHTS="QR274,QR284,QR934"

# Airfleets.net: locally, cron uses Playwright Chromium (install: npx playwright install chromium).
# Plain HTTP hits captcha/Cloudflare. Set to 0 only to force fragile HTTP-only fetches.
# AIRFLEETS_BROWSER=0
#
# If Airfleets times out in headless Chromium, try system Chrome (install Google Chrome) and:
# PLAYWRIGHT_AIRFLEETS_CHANNEL=chrome
# Or run a visible window so you can pass challenges manually:
# PLAYWRIGHT_AIRFLEETS_HEADED=1
